{
  "data_dir": "data/history_2025-05-01_2025-10-31",
  "symbols": ["BTCUSDT", "ETHUSDT", "SOLUSDT"],
  "models": [
    "ifvg_retest",
    "reclaimed_ob",
    "rejection_block"
  ],
  "smt_pairs": ["BTCUSDT:ETHUSDT", "ETHUSDT:SOLUSDT"],
  "thresholds": [0, 50, 70],
  "context_mode": "strict",
  "pre_model_require_htf_poi": true,
  "forward_bars": 20,
  "warmup_bars": 100,
  "turtle_soup_require_smt": true,
  "turtle_soup_require_mss_confirmation": true,
  "turtle_soup_require_confirmation_fvg": true,
  "turtle_soup_min_wick_atr_ratio": 0.25,
  "turtle_soup_max_confirmation_bars": 35,
  "turtle_soup_allowed_swing_significances": ["intermediate", "long"],
  "breaker_max_trigger_to_retest_bars": 12,
  "breaker_max_retest_count": 1,
  "breaker_require_displacement": true,
  "max_ifvg_retest_bars": 48,
  "ifvg_entry_mode": "edge",
  "ifvg_stop_mode": "ce",
  "ifvg_max_source_touches_before_inversion": 12,
  "ifvg_max_source_age_bars": 100,
  "model_filters": {
    "turtle_soup": {
      "enabled": false,
      "min_target_distance_r": 3.0,
      "allowed_htf_locations": ["discount", "premium"]
    },
    "silver_bullet": {
      "enabled": false,
      "min_target_distance_r": 2.0,
      "require_session_window": true,
      "exclude_no_trade_reasons": ["equilibrium", "poor_pd_location", "target_rr_below_2"]
    },
    "ifvg_retest": {
      "min_target_distance_r": 3.0,
      "allowed_displacement_grades": ["valid", "strong"],
      "exclude_no_trade_reasons": ["equilibrium", "poor_pd_location", "target_rr_below_2"]
    },
    "ict2022_mss_fvg": {
      "enabled": false,
      "min_target_distance_r": 2.0,
      "require_session_window": true,
      "allowed_displacement_grades": ["strong"]
    },
    "breaker_block": {
      "enabled": false,
      "min_target_distance_r": 2.0,
      "exclude_no_trade_reasons": ["target_rr_below_2"]
    },
    "reclaimed_ob": {
      "min_target_distance_r": 2.0,
      "exclude_no_trade_reasons": ["target_rr_below_2"]
    },
    "rejection_block": {
      "min_target_distance_r": 2.0,
      "exclude_no_trade_reasons": ["equilibrium", "poor_pd_location", "target_rr_below_2"]
    },
    "mitigation_block": {
      "enabled": false,
      "min_target_distance_r": 2.0,
      "exclude_no_trade_reasons": ["equilibrium", "poor_pd_location", "target_rr_below_2"]
    }
  },
  "runs": [
    {
      "name": "1h_strict_spec",
      "timeframes": ["1h"],
      "out_dir": "backtest_results/batch_score_may_oct_2025_1h_strict_spec"
    },
    {
      "name": "4h_strict_spec",
      "timeframes": ["4h"],
      "out_dir": "backtest_results/batch_score_may_oct_2025_4h_strict_spec"
    },
    {
      "name": "30m_btc_strict_spec",
      "symbols": ["BTCUSDT"],
      "timeframes": ["30m"],
      "out_dir": "backtest_results/batch_score_may_oct_2025_30m_btc_strict_spec"
    }
  ]
}
