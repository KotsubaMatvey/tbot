{
  "data_dir": "data/history_2025-01-01_2025-12-31",
  "symbols": ["BTCUSDT", "ETHUSDT", "SOLUSDT"],
  "models": [
    "ifvg_retest",
    "reclaimed_ob",
    "rejection_block"
  ],
  "smt_pairs": ["BTCUSDT:ETHUSDT", "ETHUSDT:SOLUSDT"],
  "thresholds": [0, 50, 70],
  "context_mode": "strict",
  "pre_model_require_htf_poi": true,
  "forward_bars": 20,
  "warmup_bars": 100,
  "tp1_r": 1.0,
  "partial_close_fraction": 0.3,
  "move_to_be_after_tp1": true,
  "max_ifvg_retest_bars": 48,
  "ifvg_entry_mode": "edge",
  "ifvg_stop_mode": "ce",
  "ifvg_max_source_touches_before_inversion": 12,
  "ifvg_max_source_age_bars": 100,
  "model_filters": {
    "ifvg_retest": {
      "min_target_distance_r": 3.0,
      "allowed_displacement_grades": ["valid", "strong"],
      "exclude_no_trade_reasons": ["equilibrium", "poor_pd_location", "target_rr_below_2"]
    },
    "reclaimed_ob": {
      "min_target_distance_r": 2.0,
      "exclude_no_trade_reasons": ["target_rr_below_2"]
    },
    "rejection_block": {
      "min_target_distance_r": 2.0,
      "exclude_no_trade_reasons": ["equilibrium", "poor_pd_location", "target_rr_below_2"]
    }
  },
  "runs": [
    {
      "name": "1h_strict_tp1_1r_p30",
      "timeframes": ["1h"],
      "out_dir": "backtest_results/full_2025_updated_1h_strict_tp1_1r_p30"
    },
    {
      "name": "4h_strict_tp1_1r_p30",
      "timeframes": ["4h"],
      "out_dir": "backtest_results/full_2025_updated_4h_strict_tp1_1r_p30"
    },
    {
      "name": "30m_btc_strict_tp1_1r_p30",
      "symbols": ["BTCUSDT"],
      "timeframes": ["30m"],
      "out_dir": "backtest_results/full_2025_updated_30m_btc_strict_tp1_1r_p30"
    }
  ]
}
