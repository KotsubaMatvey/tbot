{
  "data_dir": "data/history_2025-05-01_2025-10-31",
  "symbols": ["BTCUSDT", "ETHUSDT", "SOLUSDT"],
  "models": ["breaker_block"],
  "smt_pairs": ["BTCUSDT:ETHUSDT", "ETHUSDT:SOLUSDT"],
  "thresholds": [0, 50, 70],
  "context_mode": "strict",
  "pre_model_require_htf_poi": true,
  "forward_bars": 20,
  "warmup_bars": 100,
  "breaker_max_trigger_to_retest_bars": 12,
  "breaker_max_retest_count": 1,
  "breaker_require_displacement": true,
  "model_filters": {
    "breaker_block": {
      "min_target_distance_r": 2.0,
      "allowed_displacement_grades": ["valid", "strong"],
      "exclude_no_trade_reasons": ["target_rr_below_2"]
    }
  },
  "runs": [
    {
      "name": "1h_breaker_research",
      "timeframes": ["1h"],
      "out_dir": "backtest_results/breaker_research_may_oct_2025_1h"
    },
    {
      "name": "4h_breaker_research",
      "timeframes": ["4h"],
      "out_dir": "backtest_results/breaker_research_may_oct_2025_4h"
    },
    {
      "name": "30m_btc_breaker_research",
      "symbols": ["BTCUSDT"],
      "timeframes": ["30m"],
      "out_dir": "backtest_results/breaker_research_may_oct_2025_30m_btc"
    }
  ]
}
